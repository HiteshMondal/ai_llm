# ── App ──────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=false

# ── LLM Provider ─────────────────────────────────────
LLM_PROVIDER=ollama               # ollama | openai | huggingface
LLM_MODEL=llama3.2
LLM_BASE_URL=http://localhost:11434
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2048

# OpenAI (only if LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-...

# HuggingFace (only if LLM_PROVIDER=huggingface)
HUGGINGFACE_API_KEY=hf_...

# ── Embeddings ────────────────────────────────────────
EMBEDDING_PROVIDER=ollama         # ollama | openai | sentence-transformers
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_BASE_URL=http://localhost:11434

# ── Vector Store ──────────────────────────────────────
VECTOR_STORE_PROVIDER=chroma      # chroma | faiss | qdrant
CHROMA_PERSIST_DIR=./data/embeddings
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ── Logging ───────────────────────────────────────────
LOG_LEVEL=INFO

# ── Security ──────────────────────────────────────────
SECRET_KEY=change-me-in-production
