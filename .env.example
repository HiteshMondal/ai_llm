# App
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=false
UI_PORT=7860

# LLM
# only used when provider=ollama
LLM_MODEL=tinyllama
LLM_BASE_URL=http://localhost:11434
LLM_TEMPERATURE=0.2
# For weak hardware: use groq or gemini (free, no local model needed)
# ollama | gemini | groq | openrouter | openai
LLM_PROVIDER=ollama

# Embeddings — for weak hardware set to gemini (free, no local model)
# local | gemini | openai
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Free API keys
GEMINI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=

# Paid (optional)
OPENAI_API_KEY=

# Connectors
NOTION_TOKEN=
GITHUB_TOKEN=
GITHUB_REPOS=
GDRIVE_FOLDER_ID=

VECTOR_COLLECTION_NAME=rag_docs
CHROMA_PERSIST_DIR=data/embeddings

CHUNK_SIZE=500
CHUNK_OVERLAP=50
